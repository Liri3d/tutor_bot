graph TD
    subgraph "Просмотр"
        F3a[Показать расписание] --> F3h[Выбрать занятие]
        F3h --> F3h_check{paid = false?}
        F3h_check -- Да --> F3h_pay[Кнопка: Отметить как оплаченное]
        F3h_pay --> F3h_pay_action[Обновить paid = true]
        F3h_check -- Нет --> F3i[Отметить проведённым]
        F3h --> F3i[Отметить проведённым]
        F3i --> F3j[status = completed]
        
        F3a --> F3k[Показать занятия с долгами]
        F3k --> F3l[Подсветить красным: ученик должен N занятий]
    end

    subgraph "Добавление занятия (пошагово)"
        F3b[Добавить занятие] --> F3c[Шаг 1: Ученик]
        F3c --> F3c_check_balance{Баланс > 0?}
        
        F3c_check_balance -- Да --> F3d1[Шаг 2: Дата]
        F3c_check_balance -- Нет --> F3c_debt[Предупреждение: У ученика 0 занятий. Занятие будет создано как ДОЛГ]
        F3c_debt --> F3d1
        
        F3d1[Шаг 2: Дата] --> F3d1_check{Дата >= сегодня?}
        F3d1_check -- Нет --> F3d1_error[Ошибка: Нельзя создавать занятие в прошлом]
        F3d1_error --> F3d1
        
        F3d1_check -- Да --> F3d2[Шаг 3: Время]
        F3d2 --> F3d2_check{Время >= now?}
        F3d2_check -- Нет --> F3d2_error[Ошибка: Нельзя создать занятие раньше чем сейчас]
        F3d2_error --> F3d2
        
        F3d2_check -- Да --> F3d3[Шаг 4: Длительность]
        F3d3 --> F3d3_check{Длительность 10-180 мин?}
        F3d3_check -- Нет --> F3d3_error[Ошибка: Диапазон 10-180]
        F3d3_error --> F3d3
        
        F3d3_check -- Да --> F3d_time_check{start_time + duration <= 23:59}
        F3d_time_check -- Нет --> F3d_time_error[Ошибка: Занятие выходит за пределы дня. Укажите более раннее время или меньшую длительность]
        F3d_time_error --> F3d2

        F3d_time_check -- Да --> F3d{Проверка: есть ли занятия, где start_time <= new_start_time + duration И end_time >= new_start_time}
        
        F3d -- Да --> F3e[Ошибка: Время пересекается с уже запланированным занятием]
        F3e --> F3d2
        
        F3d -- Нет --> F3d4[Шаг 5: Предмет]
        F3d4 --> F3f_check_debt{Был ли баланс 0?}
        F3f_check_debt -- Да --> F3f_debt[Сохранить занятие: status = 'scheduled', paid = false]
        F3f_check_debt -- Нет --> F3f[Сохранить занятие: status = 'scheduled', paid = true]
        F3f_debt --> F3g1[Отправить уведомление ученику: Новое занятие назначено на ... Стоимость: X руб. Внимание: оно не оплачено. Свяжитесь с репетитором для оплаты.]
        F3f --> F3g2[Отправить уведомление ученику: Новое занятие назначено на ...]
        F3g1 --> F3a3[Возврат к расписанию]
        F3g2 --> F3a3
        F3a3 --> F3a
    end